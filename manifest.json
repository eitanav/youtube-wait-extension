{
  "manifest_version": 3,
  "name": "YouTube 5-Second Wait",
  "version": "1.2",
  "key": "",
  "description": "ממתין לפני כניסה ליוטיוב + מעקב זמן בזבוז + הגדרות מותאמות",
  "permissions": ["webNavigation", "tabs", "storage", "alarms"],
  "host_permissions": ["*://*.youtube.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "הגדרות YouTube Wait",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["wait.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
